# Copy to .env.local (local dev) or /opt/orbya/.env.prod (production).
# Never commit either file.

# ── Database (self-hosted PostgreSQL) ────────────────────────────────────────
# Local dev: postgres container from docker-compose.yml
# Production: postgres container in docker-compose.prod.yml (same Docker network)
DATABASE_URL="postgresql://orbya:password@localhost:5432/orbya"

# PostgreSQL container credentials (used by docker-compose.prod.yml)
POSTGRES_USER="orbya"
POSTGRES_PASSWORD=""
POSTGRES_DB="orbya"

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── Auth ──────────────────────────────────────────────────────────────────────
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""

# ── Payments (Stripe) ─────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PUBLISHABLE_KEY=""

# ── Email (Brevo) ─────────────────────────────────────────────────────────────
BREVO_API_KEY=""
BREVO_SMTP_KEY=""
BREVO_SMTP_HOST="smtp-relay.brevo.com"
BREVO_SMTP_PORT="587"

# ── SMS (Twilio) ──────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# ── File storage (Cloudinary) ─────────────────────────────────────────────────
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
CLOUDINARY_URL="cloudinary://<api_key>:<api_secret>@<cloud_name>"

# ── Maps ──────────────────────────────────────────────────────────────────────
MAPBOX_TOKEN=""

# ── Search (Meilisearch) ──────────────────────────────────────────────────────
# Local dev: http://localhost:7700
# Production: http://meilisearch:7700  (Docker service name)
MEILISEARCH_HOST="http://localhost:7700"
MEILISEARCH_API_KEY=""
